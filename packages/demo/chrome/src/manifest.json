{
	"manifest_version": 3,
	"name": "ext-reloader-next chrome demo",
	"version": "0.0.0",
	"description": "Minimal MV3 extension for testing webpack-ext-reloader-next on Chrome.",
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["*://*/*"],
			"js": ["content.js"]
		}
	],
	"action": {
		"default_popup": "popup.html",
		"default_title": "ext-reloader-next chrome demo"
	},
	"permissions": ["scripting", "tabs", "storage"]
}
