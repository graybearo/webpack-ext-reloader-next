{
	"manifest_version": 3,
	"name": "ext-reloader-next firefox demo",
	"version": "0.0.0",
	"description": "Minimal MV3 extension for testing webpack-ext-reloader-next on Firefox.",
	"browser_specific_settings": {
		"gecko": {
			"id": "firefox-demo@ext-reloader-next.local"
		}
	},
	"background": {
		"service_worker": "background.js",
		"scripts": ["background.js"]
	},
	"content_scripts": [
		{
			"matches": ["*://*/*"],
			"js": ["content.js"]
		}
	],
	"action": {
		"default_popup": "popup.html",
		"default_title": "ext-reloader-next firefox demo"
	},
	"permissions": ["scripting", "tabs", "storage"]
}
